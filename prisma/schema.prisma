generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // 앱 런타임은 Supabase 트랜잭션 풀러(6543)를 사용한다
  url       = env("DATABASE_URL")
  // 마이그레이션/seed는 직접 연결(5432)을 사용한다
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  ACTOR
}

enum EpisodeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// 대분류(구성) — 숏츠(완결 단편) / 시리즈(작품→회차). 콘텐츠 확장의 최상위 축.
enum EpisodeFormat {
  SHORT
  SERIES
}

// 화풍(중분류) — 웹툰체 / 상황극 / 애니메이션. 그림 스타일 축. (format과 독립)
enum EpisodeCategory {
  WEBTOON
  ROLEPLAY
  ANIMATION
}

enum PerformanceStatus {
  DRAFT
  READY
  RENDERING
  RENDERED
  FAILED
}

enum RenderStatus {
  QUEUED
  RUNNING
  DONE
  FAILED
}

model User {
  id             String        @id @default(cuid())
  handle         String        @unique
  clerkUserId    String?       @unique
  supabaseUserId String?       @unique
  email          String?       @unique
  displayName    String
  role         UserRole      @default(ACTOR)
  performances Performance[]
  recordings   Recording[]
  createdEpisodes Episode[]  @relation("creator")
  likes        Like[]
  comments     Comment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Episode {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  logline      String
  status       EpisodeStatus   @default(DRAFT)
  format       EpisodeFormat   @default(SHORT)
  category     EpisodeCategory @default(WEBTOON)
  maxSeconds   Int             @default(60)
  thumbnailUrl String?
  creatorId    String?
  creator      User?           @relation("creator", fields: [creatorId], references: [id], onDelete: SetNull)
  characters   Character[]
  cuts         Cut[]
  performances Performance[]
  likes        Like[]
  comments     Comment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([creatorId])
}

model Like {
  id        String   @id @default(cuid())
  userId    String
  episodeId String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, episodeId])
  @@index([episodeId])
}

model Comment {
  id        String   @id @default(cuid())
  episodeId String
  userId    String
  text      String
  episode   Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([episodeId, createdAt])
}

model Character {
  id          String     @id @default(cuid())
  episodeId   String
  name        String
  description String
  voiceGuide  String
  color       String
  episode     Episode    @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  dialogues   Dialogue[]

  @@index([episodeId])
}

model Cut {
  id         String     @id @default(cuid())
  episodeId  String
  order       Int
  imageUrl    String
  caption     String
  cameraHint  String?
  imagePrompt String?
  episode    Episode    @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  dialogues  Dialogue[]

  @@unique([episodeId, order])
  @@index([episodeId])
}

model Dialogue {
  id          String      @id @default(cuid())
  cutId       String
  characterId String?
  order       Int
  text        String
  direction   String
  cut         Cut         @relation(fields: [cutId], references: [id], onDelete: Cascade)
  character   Character?  @relation(fields: [characterId], references: [id], onDelete: SetNull)
  recordings  Recording[]

  @@unique([cutId, order])
  @@index([cutId])
  @@index([characterId])
}

model Performance {
  id          String            @id @default(cuid())
  episodeId   String
  userId      String
  title       String
  status      PerformanceStatus @default(DRAFT)
  isPublic    Boolean           @default(false)
  episode     Episode           @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  recordings  Recording[]
  renderJobs  RenderJob[]
  videos      RenderedVideo[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([episodeId])
  @@index([userId])
}

model Recording {
  id            String      @id @default(cuid())
  performanceId String
  dialogueId    String
  userId        String
  audioUrl      String
  storageKey    String
  durationMs    Int
  takeNumber    Int         @default(1)
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  dialogue      Dialogue    @relation(fields: [dialogueId], references: [id], onDelete: Cascade)
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([performanceId])
  @@index([dialogueId])
  @@index([userId])
}

model RenderJob {
  id            String      @id @default(cuid())
  performanceId String
  status        RenderStatus @default(QUEUED)
  timeline      Json
  error         String?
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  video         RenderedVideo?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([performanceId])
}

model RenderedVideo {
  id            String      @id @default(cuid())
  performanceId String
  renderJobId   String      @unique
  videoUrl      String
  durationMs    Int
  width         Int         @default(1080)
  height        Int         @default(1920)
  performance   Performance @relation(fields: [performanceId], references: [id], onDelete: Cascade)
  renderJob     RenderJob   @relation(fields: [renderJobId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())

  @@index([performanceId])
}
